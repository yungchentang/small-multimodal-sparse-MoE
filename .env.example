# Copy this file to .env.runai for cluster submission. The local file is ignored.
# Local cache and optional persistent virtual environment.
HF_HOME="$HOME/.cache/huggingface"
VENV_PATH=".venv"

# Optional speech shared-path InfoNCE objective (disabled by default).
SPEECH_SHARED_CONTRASTIVE_COEF="0.0"
SPEECH_SHARED_CONTRASTIVE_TEMPERATURE="0.07"
SPEECH_TEACHER_BANK_BATCH_SIZE="64"

# Required only by scripts/submit_runai.sh.
PROJECT=""
IMAGE=""
RUN_AS_UID=""
RUN_AS_GID=""
REPO_DIR=""
SCRATCH_PVC=""
SCRATCH_MOUNT=""
HOME_PVC=""
HOME_MOUNT=""
